    end
    
    local count = 0
    for _ in pairs(Amigos) do count = count + 1 end
    CountLabel.Text = "⭐ Amigos: " .. count
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local name = plr.Name
            if query == "" or name:lower():find(query) then
