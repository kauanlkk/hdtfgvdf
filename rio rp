    VerificarTime = true, Predicao = true, PredicaoValor = 0.35, SempreAtivo = false,
    Suavidade = 0
}

local Mirando = false
local AlvoAtual = nil
local ComArma = false
local ArmaAtual = "Nenhuma"
local CacheVelocidade = {}
local UltimasPosicoes = {}
local Amigos = {}

local function EhTime(plr)
    if not Config.VerificarTime then return false end
    if not plr.Team or not LocalPlayer.Team then return false end
    return plr.Team == LocalPlayer.Team
end

local function EhAmigo(nome) return Amigos[nome] == true end

local function VerificarArmaNaMao()
    local char = LocalPlayer.Character
    if not char then ComArma = false; ArmaAtual = "Nenhuma"; return false end
    for _, item in pairs(char:GetChildren()) do
        if item:IsA("Tool") then ComArma = true; ArmaAtual = item.Name; return true end
    end
    ComArma = false; ArmaAtual = "Nenhuma"; return false
end

task.spawn(function()
    while task.wait(0.05) do pcall(VerificarArmaNaMao) end
end)

task.spawn(function()
    while task.wait(0.033) do
        pcall(function()
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        if UltimasPosicoes[plr] then CacheVelocidade[plr] = (hrp.Position - UltimasPosicoes[plr]) * 30 end
                        UltimasPosicoes[plr] = hrp.Position
                    end
                end
            end
        end)
    end
end)

local function CalcularPredicao(plr, cabeca)
    if not Config.Predicao then return cabeca.Position end
    local vel = CacheVelocidade[plr]
    if not vel or vel.Magnitude < 0.1 then return cabeca.Position end
    local dist = (Camera.CFrame.Position - cabeca.Position).Magnitude
    return cabeca.Position + (vel * (dist / 800) * Config.PredicaoValor)
end

local function BuscarAlvo()
    local telaCentro = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local melhorAlvo, menorDistTela = nil, Config.FOV + 1
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and not EhTime(plr) and not EhAmigo(plr.Name) then
            local hum, cabeca = plr.Character:FindFirstChild("Humanoid"), plr.Character:FindFirstChild("Head")
            if hum and cabeca and hum.Health > 0 then
                local meuHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if not meuHRP then continue end
                if (meuHRP.Position - cabeca.Position).Magnitude > Config.DistanciaMax then continue end
                local posTela = Camera:WorldToViewportPoint(cabeca.Position)
                local dist2D = (Vector2.new(posTela.X, posTela.Y) - telaCentro).Magnitude
                if dist2D <= Config.FOV and dist2D < menorDistTela then
                    menorDistTela, melhorAlvo = dist2D, {Jogador = plr, Cabeca = cabeca}
                end
            end
        end
    end
    return melhorAlvo
end

RunService.RenderStepped:Connect(function()
    if not Config.AimbotAtivo or not Mirando then AlvoAtual = nil; return end
    if not Config.SempreAtivo and not ComArma then return end
    if AlvoAtual and AlvoAtual.Jogador and AlvoAtual.Jogador.Character then
        local cabeca, hum = AlvoAtual.Jogador.Character:FindFirstChild("Head"), AlvoAtual.Jogador.Character:FindFirstChild("Humanoid")
        if cabeca and hum and hum.Health > 0 and not EhTime(AlvoAtual.Jogador) then
            local pos = CalcularPredicao(AlvoAtual.Jogador, cabeca)
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, pos)
            return
        else AlvoAtual = nil end
    end
    local novoAlvo = BuscarAlvo()
    if novoAlvo then AlvoAtual = novoAlvo; Camera.CFrame = CFrame.new(Camera.CFrame.Position, CalcularPredicao(AlvoAtual.Jogador, AlvoAtual.Cabeca)) end
end)

